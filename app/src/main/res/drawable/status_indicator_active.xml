<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/status_indicator_active.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#332EA043" />
        </shape>
    </item>
    <!-- Inner circle -->
    <item
        android:bottom="16dp"
        android:left="16dp"
        android:right="16dp"
        android:top="16dp">
        <shape android:shape="oval">
            <solid android:color="#2EA043" />
        </shape>
    </item>
</layer-list>