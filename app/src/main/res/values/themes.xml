<?xml version="1.0" encoding="utf-8"?>
<!-- res/values/themes.xml (add these styles) -->
<resources>
    
    <style name="Theme.OTPForwarder" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorSecondaryVariant">@color/accent_green</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:statusBarColor">@color/card_background</item>
    </style>
    
    <style name="ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
    </style>
    
    <style name="LogsDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:background">@color/card_background</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="materialAlertDialogTitleTextStyle">@style/LogsDialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/LogsDialogBody</item>
    </style>
    
    <style name="LogsDialogTitle" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="LogsDialogBody" parent="MaterialAlertDialog.Material3.Body.Text">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
    </style>
    
</resources>